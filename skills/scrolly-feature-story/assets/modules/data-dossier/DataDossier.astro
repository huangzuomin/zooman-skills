---
const {
  id = "data",
  eyebrow = "Data Dossier",
  title = "Evidence and metrics",
  intro = "",
  metrics = [],
  evidence = [],
  sourceNote = ""
} = Astro.props;
---

<section class="sf-data-dossier" id={id} aria-labelledby={`${id}-title`}>
  <div class="sf-data-dossier__intro">
    <p class="sf-module-eyebrow">{eyebrow}</p>
    <h2 id={`${id}-title`}>{title}</h2>
    {intro && <p>{intro}</p>}
    {sourceNote && <p class="sf-data-dossier__source">{sourceNote}</p>}
  </div>

  <div class="sf-data-dossier__board">
    {metrics.map((metric) => (
      <article class="sf-data-metric">
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
        <p>{metric.note}</p>
      </article>
    ))}
  </div>

  {evidence.length > 0 && (
    <div class="sf-data-dossier__evidence" aria-label="Evidence notes">
      {evidence.map((item) => (
        <article>
          <p>{item.kicker}</p>
          <h3>{item.title}</h3>
          <span>{item.body}</span>
        </article>
      ))}
    </div>
  )}
</section>

