---
const { id = "cases", eyebrow, title, cases } = Astro.props;
---

<section class="case-wall" id={id} aria-labelledby={`${id}-title`}>
  <div class="section-heading reveal">
    <p class="eyebrow">{eyebrow}</p>
    <h2 id={`${id}-title`}>{title}</h2>
  </div>
  <div class="case-wall__grid">
    {cases.map((item) => (
      <article class="case-clipping reveal">
        <p class="case-clipping__label">{item.label}</p>
        <h3>{item.title}</h3>
        <p>{item.body}</p>
        <div class="tag-row">
          {item.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </article>
    ))}
  </div>
</section>

