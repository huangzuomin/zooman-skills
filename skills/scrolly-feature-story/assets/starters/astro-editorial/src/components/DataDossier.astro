---
const { id = "data", eyebrow, title, metrics } = Astro.props;
---

<section class="data-dossier reveal" id={id} aria-labelledby={`${id}-title`}>
  <div>
    <p class="eyebrow">{eyebrow}</p>
    <h2 id={`${id}-title`}>{title}</h2>
    <p class="section-copy">Use real metrics, source notes, and annotations. Replace these starter values before publishing.</p>
  </div>
  <div class="metric-board">
    {metrics.map((metric) => (
      <article>
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
        <p>{metric.note}</p>
      </article>
    ))}
  </div>
</section>

