---
const { organization, navItems, navLabel = "页面章节" } = Astro.props;
---

<header class="site-header" data-site-header>
  <a class="brand" href="#top" aria-label="Back to top">{organization}</a>
  <nav class="site-nav" aria-label={navLabel}>
    {navItems.map((item) => (
      <a href={item.href} data-nav-link>{item.label}</a>
    ))}
  </nav>
</header>
